# =============================================================================
# KDD Agentic Factory — Paper Reproducibility Kit (Production)
# =============================================================================
# Application
APP_ENV=production
APP_NAME=kdd-paper-reproducibility-kit
PORT=8090
LOG_LEVEL=INFO
HOST=0.0.0.0

# Data directories (mounted volumes)
DATA_DIR=/data/papers
RESULTS_DIR=/data/results
DATASETS_DIR=/data/datasets
ARTIFACTS_DIR=/data/artifacts

# Experiment reproducibility
REPRODUCIBILITY_CONFIG=/app/reproducibility.yaml

# Internal service URLs (Kubernetes DNS)
KDD_PIPELINES_URL=http://06-kdd-data-pipelines.kdd-agentic.svc.cluster.local:8010
EXPERIMENTATION_LAB_URL=http://08-experimentation-lab.kdd-agentic.svc.cluster.local:8060

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.kdd-observability.svc.cluster.local:4317

# CORS
CORS_ORIGINS=https://race.kdd-agentic.example.com,https://copilot.kdd-agentic.example.com
